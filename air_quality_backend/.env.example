# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=air_quality_user
DB_PASSWORD=air_quality_password
DB_NAME=air_quality_db

# Server
SERVER_PORT=8088

# JWT — đổi thành chuỗi ngẫu nhiên dài khi deploy production
JWT_SECRET=change-this-to-a-long-random-secret

# Môi trường
ENV=development

# InfluxDB Cloud
INFLUX_URL=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN=your-influxdb-cloud-token-here
INFLUX_ORG=NCKH
INFLUX_BUCKET=SENSOR
INFLUX_MEASUREMENT=sensor_data

# Tài khoản admin mặc định — tạo tự động khi server khởi động lần đầu
# Nếu để trống, không seed admin (phải tạo thủ công qua DB)
# Sau khi deploy, đổi mật khẩu qua POST /v1/users/me/change-password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456


# ML Service (Python FastAPI — airquality-ml-modeling)
ML_SERVICE_URL=http://localhost:8000
